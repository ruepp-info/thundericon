{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "1.0.28",
  "author": "Thundericon",
  "default_locale": "en",

  "browser_specific_settings": {
    "gecko": {
      "id": "thundericon@thundericon.addons",
      "strict_min_version": "128.0",
      "strict_max_version": "141.*"
    }
  },

  "permissions": [
    "storage"
  ],

  "background": {
    "scripts": ["src/config.js", "background.js"]
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "experiment_apis": {
    "threadPaneAvatars": {
      "schema": "api/threadpane/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["threadPaneAvatars"]],
        "script": "api/threadpane/implementation.js"
      }
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  }
}
